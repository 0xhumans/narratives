# Narrative Intelligence Engine — environment variables
# Copy to backend/.env and fill in real values.

# Neon Postgres (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DATABASE?sslmode=require

# GLM via OpenRouter — https://openrouter.ai/keys
GLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
GLM_BASE_URL=https://openrouter.ai/api/v1
GLM_MODEL=z-ai/glm-5.2
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Narrative Intelligence Engine
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=8000
LLM_MAX_RETRIES=2

# Pipeline (local only — set false on shared/public API hosts)
PIPELINE_CONCURRENCY=5
PIPELINE_ENABLED=true

# API / CORS (comma-separated JSON array)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://127.0.0.1:8000"]

ENV=dev
